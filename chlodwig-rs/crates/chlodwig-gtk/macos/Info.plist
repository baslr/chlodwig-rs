<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Chlodwig</string>
    <key>CFBundleDisplayName</key>
    <string>Chlodwig</string>
    <key>CFBundleIdentifier</key>
    <string>rs.chlodwig.gtk</string>
    <key>CFBundleVersion</key>
    <string>0.1.0</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>chlodwig-gtk</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSSupportsAutomaticGraphicsSwitching</key>
    <true/>
    <!-- Explicitly declare no document types so macOS does NOT show
         Chlodwig in "Open With" context menus for any file type. -->
    <key>CFBundleDocumentTypes</key>
    <array/>
    <!-- Auto-load bundled fonts from Contents/Resources/Fonts/ at app
         launch via CoreText. This makes Sarasa Mono J available BEFORE
         any GTK/Pango code runs, eliminating the first-launch race
         where install_bundled_cjk_font() writes to ~/Library/Fonts/
         too late for the current process to see it. -->
    <key>ATSApplicationFontsPath</key>
    <string>Fonts</string>
</dict>
</plist>
